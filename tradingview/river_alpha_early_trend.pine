//@version=6
indicator("River Alpha — Early Trend", shorttitle="River Early", overlay=true, max_labels_count=500)

// River Alpha core: look for fresh early uptrends, not late momentum.
groupTrend = "Trend"
emaFastLen = input.int(9, "EMA Fast", minval=1, group=groupTrend)
emaSlowLen = input.int(20, "EMA Slow", minval=2, group=groupTrend)
emaTrendLen = input.int(50, "EMA Trend", minval=2, group=groupTrend)
requireAboveTrend = input.bool(true, "Require price above EMA Trend", group=groupTrend)
requireRisingSlow = input.bool(true, "Require EMA Slow rising", group=groupTrend)

groupFresh = "Fresh Cross Policy"
int maxFreshBars = 2
showPrepare = input.bool(true, "Show PREPARE while cross is fresh", group=groupFresh, tooltip="PREPARE also requires a real EMA9/EMA20 bullish cross within 0–2 bars.")

groupVolume = "Volume"
volumeLen = input.int(20, "Volume average length", minval=1, group=groupVolume)
minRvol = input.float(1.20, "Minimum RVOL for BUY", minval=0.1, step=0.05, group=groupVolume)
prepareRvol = input.float(0.80, "Minimum RVOL for PREPARE", minval=0.1, step=0.05, group=groupVolume)

groupRisk = "Avoid Extended"
rsiLen = input.int(14, "RSI length", minval=2, group=groupRisk)
maxRsi = input.float(72.0, "Maximum RSI", minval=50, maxval=100, step=0.5, group=groupRisk)
maxExtensionPct = input.float(8.0, "Maximum distance above EMA Fast (%)", minval=1, maxval=50, step=0.5, group=groupRisk)

groupDisplay = "Display"
showEMAs = input.bool(true, "Show EMAs", group=groupDisplay)
showBg = input.bool(true, "Highlight fresh BUY zone", group=groupDisplay)
showTable = input.bool(true, "Show status table", group=groupDisplay)

emaFast = ta.ema(close, emaFastLen)
emaSlow = ta.ema(close, emaSlowLen)
emaTrend = ta.ema(close, emaTrendLen)
rsi = ta.rsi(close, rsiLen)
avgVol = ta.sma(volume, volumeLen)
rvol = avgVol > 0 ? volume / avgVol : na
extensionPct = emaFast > 0 ? (close / emaFast - 1) * 100 : na

// Python parity: (ema9 > ema20) and (ema9[1] <= ema20[1]).
bullishCross = emaFast > emaSlow and emaFast[1] <= emaSlow[1]
barsSinceCross = ta.barssince(bullishCross)
crossTime = ta.valuewhen(bullishCross, time, 0)
trendBullish = emaFast > emaSlow
freshCross = trendBullish and not na(barsSinceCross) and barsSinceCross <= maxFreshBars
crossOld = trendBullish and not na(barsSinceCross) and barsSinceCross > maxFreshBars
noCrossHistory = na(barsSinceCross)
slowRising = emaSlow > emaSlow[1]
priceTrendOK = close > emaTrend
trendOK = trendBullish and (not requireRisingSlow or slowRising) and (not requireAboveTrend or priceTrendOK)
notExtended = rsi <= maxRsi and extensionPct <= maxExtensionPct
volumeOK = rvol >= minRvol

// BUY, PREPARE, and WATCH candidates all remain inside the locked 0–2 bar window.
buy = freshCross and trendOK and volumeOK and notExtended
prepare = showPrepare and not buy and freshCross and trendOK and rvol >= prepareRvol and notExtended

signalText = buy ? "BUY" : prepare ? "PREPARE" : freshCross ? "WATCH" : crossOld ? "CROSS OLD" : noCrossHistory ? "NO CROSS" : "NO SETUP"
signalColor = buy ? color.lime : prepare ? color.orange : freshCross ? color.yellow : crossOld ? color.gray : color.silver

plot(showEMAs ? emaFast : na, "EMA 9", color=color.aqua, linewidth=2)
plot(showEMAs ? emaSlow : na, "EMA 20", color=color.orange, linewidth=2)
plot(showEMAs ? emaTrend : na, "EMA 50", color=color.new(color.blue, 15), linewidth=1)

plotshape(buy, title="River BUY", text="BUY", style=shape.labelup, location=location.belowbar, color=color.lime, textcolor=color.black, size=size.small)
plotshape(prepare, title="River PREPARE", text="PREPARE", style=shape.labelup, location=location.belowbar, color=color.orange, textcolor=color.black, size=size.tiny)
bgcolor(showBg and buy ? color.new(color.lime, 88) : na, title="Fresh BUY zone")

alertcondition(buy, title="River Alpha BUY", message="River Alpha BUY: {{ticker}} {{interval}} — fresh EMA9/EMA20 cross, trend and RVOL confirmed.")
alertcondition(prepare, title="River Alpha PREPARE", message="River Alpha PREPARE: {{ticker}} {{interval}} — real EMA9/EMA20 cross is 0–2 bars old; wait for volume confirmation.")
alertcondition(bullishCross, title="River Alpha EMA Cross", message="River Alpha EMA9 crossed above EMA20: {{ticker}} {{interval}}. Check RVOL and extension.")

crossDateText = na(crossTime) ? "—" : str.format_time(crossTime, "yyyy-MM-dd", syminfo.timezone)
latestBarDateText = str.format_time(time, "yyyy-MM-dd", syminfo.timezone)
barStateText = barstate.isconfirmed ? "Confirmed" : "Live"

var table status = table.new(position.top_right, 2, 10, bgcolor=color.new(color.black, 15), frame_color=color.new(color.gray, 55), frame_width=1)
if barstate.islast and showTable
    table.cell(status, 0, 0, "RIVER ALPHA", text_color=color.white, bgcolor=color.rgb(25, 25, 35))
    table.cell(status, 1, 0, signalText, text_color=signalColor, bgcolor=color.rgb(25, 25, 35))
    table.cell(status, 0, 1, "EMA 9 / 20", text_color=color.silver)
    table.cell(status, 1, 1, trendBullish ? "Bullish" : "Below", text_color=trendBullish ? color.lime : color.red)
    table.cell(status, 0, 2, "Cross age", text_color=color.silver)
    table.cell(status, 1, 2, na(barsSinceCross) ? "—" : str.tostring(barsSinceCross) + " bars", text_color=freshCross ? color.lime : color.silver)
    table.cell(status, 0, 3, "Cross date", text_color=color.silver)
    table.cell(status, 1, 3, crossDateText, text_color=na(crossTime) ? color.silver : color.white)
    table.cell(status, 0, 4, "Latest bar", text_color=color.silver)
    table.cell(status, 1, 4, latestBarDateText, text_color=color.white)
    table.cell(status, 0, 5, "Bar state", text_color=color.silver)
    table.cell(status, 1, 5, barStateText, text_color=barstate.isconfirmed ? color.lime : color.orange)
    table.cell(status, 0, 6, "RVOL", text_color=color.silver)
    table.cell(status, 1, 6, na(rvol) ? "—" : str.tostring(rvol, "#.##") + "x", text_color=volumeOK ? color.lime : color.orange)
    table.cell(status, 0, 7, "RSI", text_color=color.silver)
    table.cell(status, 1, 7, str.tostring(rsi, "#.0"), text_color=rsi <= maxRsi ? color.lime : color.red)
    table.cell(status, 0, 8, "Extension", text_color=color.silver)
    table.cell(status, 1, 8, str.tostring(extensionPct, "#.0") + "%", text_color=extensionPct <= maxExtensionPct ? color.lime : color.red)
    table.cell(status, 0, 9, "Trend filter", text_color=color.silver)
    table.cell(status, 1, 9, trendOK ? "PASS" : "WAIT", text_color=trendOK ? color.lime : color.orange)
